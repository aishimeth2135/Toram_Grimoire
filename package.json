{
  "name": "toram-grimoire",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "eslint": "vue-cli-service lint"
  },
  "dependencies": {
    "@iconify/iconify": "^1.0.7",
    "core-js": "^3.6.5",
    "papaparse": "^5.2.0",
    "recast": "^0.20.4",
    "velocity-animate": "^1.5.2",
    "vue": "^3.0.5",
    "vue-gtag-next": "^1.14.0",
    "vue-router": "^4.0.6",
    "vuex": "^4.0.0-alpha.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^1.2.2",
    "@vue/compiler-sfc": "^3.0.5",
    "autoprefixer": "9",
    "babel-eslint": "^10.1.0",
    "chinese-conv": "^1.0.1",
    "eslint": "^6.7.2",
    "eslint-plugin-jsdoc": "^33.0.0",
    "eslint-plugin-vue": "^7.0.0-alpha.0",
    "findit2": "^2.2.3",
    "less": "^4.1.1",
    "postcss": "7",
    "postcss-comment": "^2.0.0",
    "postcss-nesting": "^7.0.1",
    "postcss-variables": "^1.1.1",
    "tailwindcss": "npm:@tailwindcss/postcss7-compat",
    "vite": "^2.3.0",
    "vite-plugin-pwa": "^0.7.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint"
    },
    "plugins": [
      "jsdoc"
    ],
    "rules": {
      "jsdoc/no-undefined-types": "warn",
      "no-unused-vars": "warn",
      "no-trailing-spaces": "warn",
      "object-curly-spacing": [
        "warn",
        "always"
      ],
      "comma-spacing": [
        "warn",
        {
          "before": false,
          "after": true
        }
      ]
    }
  }
}
